APP_NAME=SimpleVault
APP_ENV=production
APP_DEBUG=false
APP_URL=https://vault.example.com

DB_CONNECTION=sqlite
DB_DATABASE=/absolute/path/to/database/database.sqlite

# MySQL (only used when DB_CONNECTION=mysql)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=simplevault
DB_USER=simplevault
DB_PASS=

SESSION_LIFETIME_MINUTES=60
VAULT_AUTO_LOCK_MINUTES=15

ALLOW_PUBLIC_REGISTRATION=false

MAX_UPLOAD_MB=10
MAX_MARKDOWN_NOTE_KB=512
MAX_IMPORT_FILES=100

# Editable setup-screen text. Leave unset to use the defaults in config/app.php.
# Use %d where the minimum password length should appear.
#SETUP_INTRO="Create the first account and your encrypted vault."
#SETUP_RECOVERY_TITLE="Important — no recovery."
#SETUP_RECOVERY_WARNING="If you lose your Master Password or Key File, your saved passwords and notes cannot be recovered. There is no reset."
#SETUP_ACCOUNT_PASSWORD_HELP="Used to log in. Minimum %d characters."
#SETUP_MASTER_PASSWORD_HELP="Minimum %d characters. It is never stored."
#SETUP_KEY_FILE_HELP="Generate an optional Key File (second factor). You will download it now and must upload it every time you unlock. Store it separately from your password."
#SETUP_RECOVERY_ACK_LABEL="I understand there is no recovery if I lose my Master Password or Key File."
