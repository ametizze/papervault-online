APP_NAME=SimpleVault
APP_ENV=production
APP_DEBUG=false
APP_URL=https://vault.example.com

DB_CONNECTION=sqlite
DB_DATABASE=/absolute/path/to/database/database.sqlite

# MySQL (only used when DB_CONNECTION=mysql)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=simplevault
DB_USER=simplevault
DB_PASS=

SESSION_LIFETIME_MINUTES=60
VAULT_AUTO_LOCK_MINUTES=15

ALLOW_PUBLIC_REGISTRATION=false

MAX_UPLOAD_MB=10
MAX_MARKDOWN_NOTE_KB=512
MAX_IMPORT_FILES=100
